# Copy to .env.local (never commit .env.local)

# --- Auth (NextAuth / Auth.js) ---
# In `npm run dev`, AUTH_SECRET defaults to a built-in dev value if unset.
# Set a real secret for stable cookies across machines or for production:
AUTH_SECRET=
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Public site URL (production): AUTH_URL=https://your-domain.com
#
# Username/password sign-in uses a lightweight signed browser check plus a honeypot field.
# Optional: AUTH_DEV_LOGIN=1 adds a passwordless "Dev login" provider (development only).

# --- Postgres (required for hosted billing + server chat history + accounts) ---
DATABASE_URL=
# Vercel/Supabase: use this direct (non-pooling) URI for `npm run db:push` — poolers often hang on schema pull
# POSTGRES_URL_NON_POOLING=
# Optional: force migrate URL only — direct Postgres, session mode (port 5432)
# DRIZZLE_DATABASE_URL=

# --- OpenRouter (server-side; when set, clients must sign in if DATABASE_URL is set) ---
OPENROUTER_API_KEY=
# Thinking (billable) and free chat modes — see src/lib/openrouter/server-models.ts
OPENROUTER_DEFAULT_MODEL=x-ai/grok-4.1-fast
# OPENROUTER_MODEL_THINKING=
OPENROUTER_MODEL_FREE=nvidia/nemotron-3-super-120b-a12b:free
OPENROUTER_MODEL_FREEFAST=stepfun/step-3.5-flash:free
OPENROUTER_MODEL_MAX=deepseek/deepseek-v3.2
OPENROUTER_DEFAULT_EMBEDDING_MODEL=openai/text-embedding-3-small
# Optional display overrides for workspace UI (otherwise derived from model ids)
# OPENROUTER_LABEL_THINKING=
# OPENROUTER_LABEL_FREE=
# OPENROUTER_LABEL_FREEFAST=
# OPENROUTER_LABEL_MAX=

# --- Polar (production) ---
# POLAR_ACCESS_TOKEN is reserved for future subscription management/portals (not currently used)
POLAR_ACCESS_TOKEN=
# Product checkout link from Polar dashboard; /api/billing/checkout appends metadata[userId]
POLAR_CHECKOUT_URL=
# Required in production when DATABASE_URL is set — same secret as Polar webhook endpoint (often whsec_...)
POLAR_WEBHOOK_SECRET=
# Webhook URL: https://<your-domain>/api/webhooks/polar (Raw JSON, Standard Webhooks)
